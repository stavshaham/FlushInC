#include "utils.h"
#include <stdio.h>

/* clearBuffer This function clears the buffer after an invalid input */
void clearBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

/* removeNewLine This function removes new line and changes it to the null char */
void removeNewLine(char* str, int len) {
    int i = 0;
    for (i = 0; str[i] != '\0'; i++) {
        if (str[i] == '\n') {
            str[i] = '\0';
            return;
        }
    }
}

/* containsSpace This function checks if there is a space in the string */
int containsSpace(char* str, int len) {
    int i = 0;
    for (i = 0; str[i] != '\0'; i++) {
        if (str[i] == ' ') {
            return 1;
        }
    }

    return 0;
}

int equalStrings(const char* str1, const char* str2) {
    while (*str1 == *str2 && *str1 != '\0') {
        str1++;
        str2++;
    }

    return (*str1 == '\0' && *str2 == '\0');
}

void copyString(char* destination, char* str) {
    sprintf(destination, "%s", str);
}
