#include <stdio.h>
#include <stdlib.h>
#include "game.h"
#include "card.h"
#include "utils.h"

#define SUITS 4
#define VALUES 13

/*
    Function: generateDeck
    Purpose: This function generates a new deck

    Arguments:
        None
    
    Returns:
        Card array
*/

void generateDeck(Card* cards) {
    int i = 0;

    for (i = 1; i <= VALUES * SUITS; i++) {
        cards[i - 1].value = (i - 1) % 13;
        switch ((i - 1) / 13) {
            case 0:
                cards[i - 1].suit = "Diamonds";
                break;
            case 1:
                cards[i - 1].suit = "Hearts";
                break;
            case 2:
                cards[i - 1].suit = "Clubs";
                break;
            case 3:
                cards[i - 1].suit = "Spades";
                break;
            default:
                perror("ERROR GENERATING THE CARDS!");
                break;
        }
    }
}

/*
    Function: shuffleDeck
    Purpose: This function shuffles the current deck

    Arguments:
        deck - an array of cards
        size - the size of the array
    
    Returns:
        None
*/

void shuffleDeck(Card* deck, int size) {
    int i = 0;
    for (i = size - 1; i > 0; i++) {
        int j = rand() % (i + 1);

        Card temp = deck[i];
        deck[i] = deck[j];
        deck[j] = temp;
    }
}

/*
    Function: dealCard
    Purpose: This function shuffles the current deck

    Arguments:
        deck - an array of cards
        size - the size of the array
    
    Returns:
        Card
*/

Card dealCard(Card* deck, int* top) {
    return deck[(*top)++];
}

void startGame() {
    Player players[PLAYERS];
    Card deck[TABLE_CARDS];
    int c = 0;
    int p = 0;
    int top = 0;

    generateDeck(deck);
    shuffleDeck(deck, TABLE_CARDS);

    for (c = 0; c < PLAYER_CARDS; c++) {
        for (p = 0; p < PLAYERS; p++) {
            players[p].cards[c] = dealCard(deck, &top);
        }
    }
    
}
